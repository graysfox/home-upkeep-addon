{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "python": "${workspaceFolder}/home-upkeep/backend/.venv/bin/python",
            "cwd": "${workspaceFolder}/home-upkeep/backend"
        },
        {
            "name": "Frontend (Firefox)",
            "type": "firefox",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceRoot}/home-upkeep/frontend/src",
            "preLaunchTask": "npm: dev - home-upkeep/frontend",
            "pathMappings": [
                {
                    "url": "http://localhost:5173/src",
                    "path": "${workspaceFolder}/home-upkeep/frontend/src"
                }
            ]
        }
    ],
    "compounds": [
        {
            "name": "Backend/Frontend",
            "configurations": ["Backend (FastAPI)", "Frontend (Firefox)"]
        }
    ]
}